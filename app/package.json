{
  "name": "remote-laser-pointer",
  "productName": "RemoteLaserPointer",
  "version": "0.2.0",
  "private": true,
  "description": "遠端雷射筆:在朋友分享的畫面上直接圈點指位",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "release:win": "electron-vite build && electron-builder --win --publish always",
    "release:mac": "electron-vite build && electron-builder --mac --publish always",
    "icon": "node scripts/gen-app-icon.mjs && bash scripts/gen-icns.sh"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "koffi": "^3.1.1",
    "socket.io-client": "^4.8.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.philio.remote-laser-pointer",
    "productName": "RemoteLaserPointer",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "deantw69",
        "repo": "remote-laser-pointer"
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/uiohook-napi/**",
      "**/node_modules/node-gyp-build/**",
      "**/node_modules/koffi/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "identity": null
    }
  }
}
